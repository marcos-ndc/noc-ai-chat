# ══════════════════════════════════════════════════════════════════════════════
# OBRIGATÓRIO — sem esta chave o agente não responde
# Obtenha em: https://console.anthropic.com/settings/keys
# ══════════════════════════════════════════════════════════════════════════════
ANTHROPIC_API_KEY=sk-ant-...

# ── Zabbix ────────────────────────────────────────────────────────────────────
ZABBIX_URL=https://seu-zabbix.empresa.com/api_jsonrpc.php
ZABBIX_USER=noc-agent
ZABBIX_PASSWORD=

# ── Datadog ───────────────────────────────────────────────────────────────────
DATADOG_API_KEY=
DATADOG_APP_KEY=
DATADOG_SITE=datadoghq.com

# ── Grafana ───────────────────────────────────────────────────────────────────
GRAFANA_URL=https://seu-grafana.empresa.com
GRAFANA_TOKEN=

# ── ThousandEyes ──────────────────────────────────────────────────────────────
# Bearer token OAuth2 (recomendado — gere em Settings > Security > User API Tokens)
THOUSANDEYES_TOKEN=
# Opcional: Basic Auth legado (email + API token como senha)
# THOUSANDEYES_USER=seu-email@empresa.com
# THOUSANDEYES_PASSWORD=seu-api-token-basico
# Opcional: Account Group ID para multi-conta
# THOUSANDEYES_AID=

# ── CORS ─────────────────────────────────────────────────────────────────────
# True em desenvolvimento (aceita qualquer origem)
# False em produção (usa CORS_ORIGINS abaixo)
CORS_ALLOW_ALL=true

# ── Auth ──────────────────────────────────────────────────────────────────────
JWT_SECRET=troque-por-uma-string-aleatoria-segura-minimo-32-chars
JWT_EXPIRY_HOURS=8

# ── Redis ─────────────────────────────────────────────────────────────────────
REDIS_URL=redis://redis:6379

# ── Portas (mude se houver conflito com outros serviços) ──────────────────────
FRONTEND_PORT=3000
BACKEND_PORT=8000
REDIS_PORT=6379

# ── URLs ──────────────────────────────────────────────────────────────────────
BACKEND_URL=http://localhost:8000

# URL pública do backend (usada pelo browser para chamar a API)
# Desenvolvimento local: http://localhost:8000
# Produção: https://api.seu-dominio.com
BACKEND_PUBLIC_URL=http://localhost:8000

# ── OpenRouter (opcional — acesso a múltiplos modelos) ────────────────────────
# Obtenha em: https://openrouter.ai/keys
# Configurar no painel /admin — não precisa colocar aqui
# OPENROUTER_API_KEY=sk-or-v1-...
# Em ambientes com proxy SSL corporativo:
OPENROUTER_SSL_VERIFY=false

# ── OpenAI TTS (opcional — voz premium tipo Jarvis) ───────────────────────────
# Obtenha em: https://platform.openai.com/api-keys
OPENAI_API_KEY=
# Voz: onyx (grave/Jarvis), echo, fable, alloy, nova, shimmer
TTS_VOICE=onyx
# Modelo: tts-1 (rápido) ou tts-1-hd (maior qualidade)
TTS_MODEL=tts-1
# Velocidade: 0.25–4.0 (0.95 = ligeiramente mais lento, mais grave)
TTS_SPEED=0.95

# ── Zabbix extras (adicionados em feature/mcp-real-integrations) ──────────────
# Zabbix 7.x: API token permanente (Administration > API tokens)
ZABBIX_API_TOKEN=
# Timeout em segundos para chamadas Zabbix/Datadog
ZABBIX_TIMEOUT=10
DATADOG_TIMEOUT=10
